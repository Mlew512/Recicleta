generator client { provider = "prisma-client-js" }
datasource db { provider = "postgresql"; url = env("DATABASE_URL") }

model User {
  id        String  @id @default(cuid())
  fullName  String
  dni       String  @unique
  phone     String?
  email     String?
  address   String?
  notes     String?
  rentals   Rental[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum BikeStatus { Disponible Alquilada EnReparacion }

model Bike {
  id             String     @id @default(cuid())
  code           String     @unique
  type           String?
  model          String?
  sizeCm         Int?
  sizeLabel      String?
  condition      String?
  status         BikeStatus @default(Disponible)
  assignedUserId String?
  assignedUser   User?      @relation(fields: [assignedUserId], references: [id])
  lastMaintenance DateTime?
  notes          String?
  rentals        Rental[]
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

enum RentalStatus { Activo Completado }

model Rental {
  id         String   @id @default(cuid())
  code       String   @unique
  bikeId     String
  bike       Bike     @relation(fields: [bikeId], references: [id])
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  startDate  DateTime
  plannedEnd DateTime?
  endDate    DateTime?
  status     RentalStatus @default(Activo)
  deposit    Int?
  fee        Int?
  refund     Int?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Sale {
  id        String   @id @default(cuid())
  code      String   @unique
  item      String
  quantity  Int      @default(1)
  unitPrice Int      @default(0)
  total     Int      @default(0)
  date      DateTime @default(now())
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
